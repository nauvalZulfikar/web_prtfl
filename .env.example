# Copy to .env.local and fill in real values. Never commit .env.local.

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-string
NEXTAUTH_URL=http://localhost:3001

# Google OAuth — get from https://console.cloud.google.com (APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Single-user whitelist (only this email may sign in)
ALLOWED_EMAIL=nauval.saga@gmail.com
